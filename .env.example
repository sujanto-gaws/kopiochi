# ===========================================
# Kopiochi - Domain-Driven Design API
# ===========================================

# -------------------------------------------
# Server Configuration
# -------------------------------------------
APP_SERVER_HOST=0.0.0.0
APP_SERVER_PORT=8080

# -------------------------------------------
# Database Configuration (PostgreSQL)
# -------------------------------------------
APP_DB_HOST=localhost
APP_DB_PORT=5432
APP_DB_USER=postgres
APP_DB_PASSWORD=postgres
APP_DB_NAME=kopiochi
APP_DB_SSLMODE=disable
APP_DB_MAX_CONNS=10
APP_DB_MIN_CONNS=2

# -------------------------------------------
# Logging Configuration
# -------------------------------------------
APP_LOG_LEVEL=info
APP_LOG_FORMAT=json

# -------------------------------------------
# Plugin Configuration
# -------------------------------------------
# JWT Authentication
APP_JWT_SECRET=your-secret-key-change-in-production
APP_JWT_EXPIRY=24h
APP_JWT_ISSUER=kopiochi

# Rate Limiting
APP_RATELIMIT_REQUESTS=100
APP_RATELIMIT_WINDOW=1m

# CORS
APP_CORS_ALLOWED_ORIGINS=https://example.com,https://app.example.com
APP_CORS_ALLOW_CREDENTIALS=true
